
extends ../../layouts/default 
include ../../mixins/alert
include ../../mixins/select-tree


block main
    +Alert(messages,5000)

    h1 #{pageTitle}
    #{treeCategory[0]}
    div
        form(
            class = "d-flex flex-column items-start px-3"
            form-edit-product
            method = "POST"
            action = `/admin/products/edit/${productDetail._id}?_method=PATCH`
            enctype ="multipart/form-data"
            required
        )
            div(class = "d-flex flex-column col-12") 
                p(class = "m-0 font-bold") Chọn Ảnh Cho Sản Phẩm
                input(type = "file" name = 'thumbnail' accept = 'image/*' change-image)
            div(class = "d-flex col-12")
                div(class = "d-flex flex-column col-6")
                    p(class = "m-0 font-bold") Ảnh Cũ
                    img(src = productDetail.thumbnail class = "col-8")
                div(class = "d-flex flex-column col-6")
                    p(class = "m-0 font-bold") Ảnh Mới
                    img(class = "col-8" id = "edit-new-image")
            div(class = "d-flex flex-column col-12") 
                p(class = "m-0 font-bold") Tiêu đề
                input(type = "text" name = 'title' value = `${productDetail.title}` required)
            div(class = "d-flex flex-column col-12") 
                p(class = "m-0 font-bold") Danh mục
                select(name = "categoryID")
                    option(value = "") Lựa chọn danh mục
                    +select-tree(treeCategory,1,productDetail.categoryID)
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Mô tả
                textarea(name = 'description' value = `${productDetail.description}`)
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Gía
                input(type = "text" name = 'price' value = `${productDetail.price}`)
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") % Giảm giá
                input(type = "text" name = 'discountPercentage')
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Số lượng
                input(type = "number" name = 'quantity' value = `${productDetail.quantity}`)
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Vị trí
                input(type = "number" placeholder = "Tự động tăng" name = 'possition')
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Sản phẩm nổi bật
                div(class = "d-flex items-center gap-x-3 col-12")
                    div(class = " gap-x-2")
                        input(type = 'checkbox' name = 'featured' value = true checked = (productDetail.featured === true ? true : false)) 
                        label Nổi bật
            div(class = "d-flex flex-column col-12")
                p(class = "m-0 font-bold") Trạng Thái
                div(class = "d-flex items-center gap-x-3 col-12")
                    div(class = " gap-x-2")
                        input(type = 'radio' name = 'active' value = 'active' checked = `${productDetail.active === "active" ? true : false}`) 
                        label Hoạt Động
                    div(class = " gap-x-2")
                        input(type = 'radio' name = 'active' value = 'inactive')
                        label Dừng Hoạt Động

            button(type = "submit" class = "bg-blue text-white border-none rounded") Xác Nhận