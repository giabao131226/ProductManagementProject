include ../mixins/loadcagory.pug


link(rel = "stylesheet" href = "css/client/header.css")
header.header-client.container-fluid.text-algin-start
    .container 
        .d-flex.items-center.justify-between
            a( class = "logo-app" href = "/")
                img(src = "image/logo-app.png")
            .d-flex.items-center.gap-x-3
                ul(class = "list-style-type-none m-0 d-flex items-center gap-x-5")
                    each item in treeCategory
                        li(class = "nav-item")
                            a(href = ("/" + item.slug) class = "d-block text-decoration-none")
                                span(class = "font-bold text-header") #{item.title}
                            if(item.children)
                                +LoadCategory(item.children)
                
                p.font-bold.rounded.m-0.text-header |
                .d-flex.gap-x-3.items-center.font-bold.text-white
                    a(href = "/cart" class = "text-header")
                        i(class="fa-solid fa-cart-shopping")
                    form(
                        action = "/search"
                        form-search-product
                        class = "search-box d-none"
                    )
                        input(name = "search" type = "text")
                        d-flex.px-2
                        button.font-bold.text-black.bg-white.border-none.rounded(type = "submit") Tìm Kiếm
                    button(class = "kinh-lup border-none px-0 py-0 bg-transparent text-header" btn-open-search-box)
                        i(class="fa-solid fa-magnifying-glass")

                    
  
                    