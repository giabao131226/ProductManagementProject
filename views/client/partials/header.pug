include ../mixins/loadcagory.pug

header.header-client.container-fluid.text-algin-start
    .container 
        .d-flex.items-center.justify-between
            .logo-app
                img(src = "https://cdn.daca.vn/media/logo/logo.svg" class = "col-2")
            .d-flex.items-center.gap-x-3
                ul(class = "list-style-type-none m-0 d-flex items-center gap-x-5")
                    each item in treeCategory
                        li(class = "nav-item")
                            a(href = ("/" + item.slug) class = "d-block text-decoration-none") #{item.title}
                            if(item.children)
                                +LoadCategory(item.children)
                
                p.font-bold.rounded.m-0 |
                .d-flex.gap-x-3.items-center
                    i(class="fa-solid fa-cart-shopping")
                    i(class="fa-solid fa-magnifying-glass")

                    
  
                    