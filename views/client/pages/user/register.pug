extends ../../layouts/default

block main
    link(rel = "stylesheet" href = "/css/client/register.css")
    .container-fluid.text-align-start.bg-white.w-100.h-100
        .container.d-flex.justify-center
            form(
                action = "/user/register" 
                method = "POST"
                class = "d-flex flex-column gap-y-3 register-form"
            )
                h3.font-bold.text-align-center.m-0 Đăng Ký Tài Khoản
                .d-flex.flex-column
                    label.font-bold.text-gray-600 Email
                    input(type = "text" name = "email" placeholder = "abc@gmail.com" class = "font-bold text-black")
                    - if(oldData.error)
                        p.text-error.m-0 #{oldData.error.errorEmail}
                .d-flex.flex-column
                    label.font-bold.text-gray-600 Password
                    input(type = "password" name = "password" placeholder = "Nhập mật khẩu" class = "font-bold text-black")
                    - if(oldData.error)
                        p.text-error.m-0 #{oldData.error.errorPassword}
                .d-flex.flex-column
                    label.font-bold.text-gray-600 Confirm Password
                    input(type = "password" name = "cfPassword" placeholder = "Nhập xác nhận mật khẩu" class = "font-bold text-black")
                    - if(oldData.error)
                        p.text-error.m-0 #{oldData.error.errorCfPasword}
                .d-flex.items-center.justify-between.font-14
                    span.font-bold Đã có tài khoản? 
                        a(href = "/user/login") Đăng Nhập
                    span.font-bold Chính sách
                button Đăng ký
                